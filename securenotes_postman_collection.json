        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"noteId\", jsonData.id);",
              "    pm.test(\"Nota creada exitosamente\", function () {",
              "        pm.response.to.have.status(201);",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
