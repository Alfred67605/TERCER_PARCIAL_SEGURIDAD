              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Mi primera nota\",\n  \"content\": \"Contenido secreto de la nota de Usuario A\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/notes",
          "host": [
            "{{baseUrl}}"
          ],
