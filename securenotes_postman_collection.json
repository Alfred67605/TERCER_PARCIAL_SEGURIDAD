  "item": [
    {
      "name": "01 - Registro Usuario A",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuarioa@test.com\",\n  \"password\": \"Password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
              "    var setCookie = pm.response.headers.get(\"Set-Cookie\");",
              "    if (setCookie) {",
              "        var match = setCookie.match(/refresh_token=([^;]+)/);",
              "        if (match) {",
              "            pm.collectionVariables.set(\"oldRefreshToken\", match[1]);",
              "        }",
              "    }",
              "    pm.test(\"Registro exitoso\", function () {",
              "        pm.response.to.have.status(201);",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
