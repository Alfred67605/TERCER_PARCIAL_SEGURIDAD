meta {
  name: 01 - Registro Usuario A
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "usuarioa@test.com",
    "password": "Password123"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("accessToken", res.body.accessToken);
    console.log("✅ Usuario A registrado. Access token guardado.");
  }
}
