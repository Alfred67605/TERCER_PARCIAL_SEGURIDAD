meta {
  name: 02 - Login Usuario A
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "usuarioa@test.com",
    "password": "Password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("accessToken", res.body.accessToken);
    console.log("✅ Login OK. Token guardado:", res.body.accessToken.substring(0,20) + "...");
  }
}
